# Copy this file to .env and fill in values before running locally.

# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave blank to use SQLite (default for local dev).
# Set to a PostgreSQL URL for production e.g. Railway injects this automatically.
DATABASE_URL=

# CORS
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vite)
# VITE_API_URL defaults to http://localhost:8000/api/v1 in development.
# Set this to your Railway backend URL for production builds.
VITE_API_URL=http://localhost:8000/api/v1
